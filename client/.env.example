# AMPERIA client — build-time env (Vite inlines VITE_* at build; placeholders only).
# Copy to client/.env for local overrides. In production this is set on the
# Vercel project (Environment Variables) BEFORE building.

# Base URL of the game server (http[s]://host[:port] — no trailing slash).
# The client derives ws:// or wss:// from this scheme automatically.
# Unset in dev ⇒ falls back to http://localhost:2567.
VITE_SERVER_URL=https://your-server.up.railway.app
