{
  "name": "amperia",
  "private": true,
  "version": "0.0.0",
  "description": "AMPERIA — isometric cozy salvage-punk MMO. Keep the city lit.",
  "workspaces": [
    "client",
    "server",
    "db"
  ],
  "scripts": {
    "dev": "npm run dev -w client",
    "dev:server": "npm run dev -w server",
    "build": "npm run build -w client && npm run build -w server",
    "test": "npm run test -w client && npm run test -w server",
    "lint": "npm run lint -w client",
    "format": "npm run format -w client",
    "db:generate": "node db/node_modules/prisma/build/index.js generate --schema db/prisma/schema.prisma",
    "db:migrate": "node db/node_modules/prisma/build/index.js migrate dev --schema db/prisma/schema.prisma",
    "db:deploy": "node db/node_modules/prisma/build/index.js migrate deploy --schema db/prisma/schema.prisma",
    "db:seed": "node server/dist/seed.mjs",
    "test:overlap": "node client/tests/overlapTour.mjs"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  },
  "devDependencies": {
    "playwright-core": "^1.61.1"
  }
}
