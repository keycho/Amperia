# AMPERIA server — environment contract (placeholders only; never commit .env).
# Copy to server/.env for local dev. In production these are set on the
# Railway service (Variables tab). Full table with sources: DEPLOY.md.

# ── Required (all environments) ──────────────────────────────────────────────
# Postgres, runtime traffic. Production = Supabase POOLED string (port 6543).
DATABASE_URL=postgresql://amperia:amperia@localhost:5432/amperia

# Postgres, migrations only (prisma migrate deploy reads directUrl).
# Production = Supabase DIRECT string (port 5432). Locally: same as above.
DIRECT_URL=postgresql://amperia:amperia@localhost:5432/amperia

# ── Required in production (validated at boot; server exits if missing) ─────
# Session-token signing secret. Generate: openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32

# Comma-separated browser origins allowed for HTTP + WebSocket (no wildcard).
# Localhost origins are auto-allowed outside production.
CORS_ORIGIN=https://your-client.vercel.app

# ── Recommended in production ────────────────────────────────────────────────
# Full Redis URL with auth, exactly as Railway provides it. Unset ⇒ runs
# without Redis; /healthz reports redis "off".
#REDIS_URL=redis://default:password@host:6379

# Key for the /metrics economy dashboard (?key=...). Unset in production ⇒
# the endpoint 404s (fails closed).
#METRICS_KEY=change-me-long-random

# Slack/Discord-style webhook that hears about restarts + uncaught errors.
#ALERT_WEBHOOK=https://hooks.example.com/services/xxx

# ── Optional (safe defaults) ─────────────────────────────────────────────────
#PORT=2567                  # Railway injects PORT; server binds 0.0.0.0
#LOG_DIR=logs               # rotating JSON logs directory
#LOG_KEEP_DAYS=7            # log retention window
#AUTH_RATE_PER_MIN=20       # per-IP /auth/* rate limit

# ── Chain / $AMP (Robinhood Chain, EVM L2 — placeholders only; see /shared/chain.ts) ──
# The token layer is M4-gated and inactive until AMP_TOKEN_ADDRESS is set. Never
# commit real values; the treasury key is server-side ONLY, never client/repo.
#ROBINHOOD_RPC_URL=          # Robinhood Chain JSON-RPC endpoint (balance reads, later txs)
#AMP_TOKEN_ADDRESS=         # $AMP ERC-20 address — UNSET until the hood.fun fair launch settles
#TREASURY_ADDRESS=          # treasury wallet (receives the 70%; never sells)
#TREASURY_PRIVATE_KEY=      # treasury signer key — SECRET, server-side only
#CREATOR_REWARDS_ENABLED=false  # buyback flag: off until hood.fun creator-fee volume is confirmed

# ── Dev/test knobs (never set in production) ─────────────────────────────────
#ROOM_MAX_CLIENTS=40        # load-test override for the measured per-room cap
#TRADE_TIMEOUT_SECONDS=     # integration-probe override for trade timeout
#DRAYMULE_TEST_MINUTES=     # shortcut Draymule spawn wait in probes
