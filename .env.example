# Copy to .env (gitignored). Dev defaults below match db/dev-postgres.md.
# NO real secrets in this file, ever — it is committed.

# ── required ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://amperia:amperia_dev@127.0.0.1:5432/amperia"
JWT_SECRET="amperia-dev-secret-change-me"          # set a REAL secret in prod
PORT=2567

# ── production switches ─────────────────────────────────────────────────
# NODE_ENV=production            # gates /metrics behind METRICS_KEY
# METRICS_KEY=                   # required to view /metrics in production

# ── ops (H4) ────────────────────────────────────────────────────────────
# LOG_DIR=logs                   # structured JSON logs, daily rotation
# LOG_KEEP_DAYS=7                # rotated files kept
# ALERT_WEBHOOK=                 # optional POST {text} on boot/uncaught errors
# AUTH_RATE_PER_MIN=20           # per-IP /auth/* rate limit

# ── tuning / test knobs ─────────────────────────────────────────────────
# ROOM_MAX_CLIENTS=40            # per-room CCU cap (see PROGRESS load test)
# TRADE_TIMEOUT_SECONDS=45       # direct-trade window expiry (dev tests use 5)
